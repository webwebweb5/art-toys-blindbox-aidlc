{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "description": "Art Toys Blind Box - NestJS API",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/src/main",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.config.integration.ts test/integration/",
    "test:properties": "vitest run --config vitest.config.integration.ts test/properties/",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "10.3.3",
    "@nestjs/config": "3.2.0",
    "@nestjs/core": "10.3.3",
    "@nestjs/event-emitter": "2.0.4",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.3.3",
    "@nestjs/platform-socket.io": "^10.3.3",
    "@nestjs/schedule": "4.0.1",
    "@nestjs/websockets": "^10.3.3",
    "@prisma/client": "5.10.2",
    "bcrypt": "5.1.1",
    "bullmq": "^5.79.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "ioredis": "5.3.2",
    "multer": "1.4.4-lts.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "0.2.1",
    "rxjs": "7.8.1",
    "socket.io": "^4.8.3",
    "stripe": "14.0.0",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "10.3.2",
    "@nestjs/schematics": "10.1.1",
    "@nestjs/testing": "10.3.3",
    "@types/bcrypt": "5.0.2",
    "@types/express": "4.17.21",
    "@types/multer": "1.4.11",
    "@types/node": "20.11.19",
    "@types/passport-jwt": "4.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "6.0.2",
    "@vitest/coverage-v8": "1.3.1",
    "fast-check": "3.15.0",
    "prisma": "5.10.2",
    "supertest": "6.3.4",
    "ts-node": "10.9.2",
    "typescript": "5.3.3",
    "vitest": "1.3.1"
  }
}
